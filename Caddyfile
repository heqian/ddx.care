# Caddyfile — ddx.care production configuration
#
# Caddy automatically obtains and renews TLS certificates via ACME/Let's Encrypt.
#
# Usage:
#   caddy run --config Caddyfile
#
# Prerequisites:
#   - Port 80 and 443 open and routable to this host
#   - DNS A record pointing your domain to this host's public IP
#   - The ddx.care app running on localhost:3000 (set PORT=3000 in .env)

ddx.care {
  # Basic authentication — password hash loaded from environment variable.
  # Generate a hash:  caddy hash-password --plaintext 'your-password'
  # Set it:          export BASIC_AUTH_HASH='$2b$10$...'
  basic_auth {
    admin {$BASIC_AUTH_HASH}
  }

  # Forward the client's real IP to the backend app
  header_up X-Real-IP {remote_host}

  reverse_proxy localhost:3000

  # Compress responses
  encode gzip
}
