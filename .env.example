# Required: LLM provider API key. The env var name depends on the provider.
# See https://mastra.ai/models/providers for provider-specific API key env var names.
# Default provider is Ollama Cloud, which uses OLLAMA_API_KEY.
OLLAMA_API_KEY=

# Server port (default: 3000)
# PORT=3000

# Override specialist agent model (default: ollama-cloud/gemma4:31b)
# See https://mastra.ai/models/providers for supported models per provider.
# SPECIALIST_MODEL=ollama-cloud/gemma4:31b

# Override CMO orchestrator model (default: ollama-cloud/gemma4:31b)
# See https://mastra.ai/models/providers for supported models per provider.
# ORCHESTRATOR_MODEL=ollama-cloud/gemma4:31b

# Max consultation rounds per diagnosis (default: 3)
# MAX_DIAGNOSIS_ROUNDS=3

# Rate limit: max diagnosis requests per IP per window (default: 5)
# RATE_LIMIT_MAX_REQUESTS=5

# Rate limit: time window in ms (default: 60000 = 1 minute)
# RATE_LIMIT_WINDOW_MS=60000

# Max concurrent diagnostic workflows (default: 3)
# MAX_CONCURRENT_WORKFLOWS=3

# Set to "1" to use mock LLM responses (for testing)
# MOCK_LLM=1

# Agent-to-agent context sharing mode (default: none)
# Options: none, prior_rounds, cmo_curated, full
# SPECIALIST_CONTEXT_MODE=none

# Max characters of context injected per specialist call (default: 2000)
# SPECIALIST_CONTEXT_MAX_CHARS=2000

# Max characters of context maintained in CMO history (default: 60000)
# CMO_CONTEXT_MAX_CHARS=60000

# Max retries for agent generation calls (default: 3)
# AGENT_GENERATE_MAX_RETRIES=3

# CORS + WebSocket origin whitelist, comma-separated (default: *)
# ALLOWED_ORIGINS=*

# Production CORS + WebSocket origin whitelist (comma-separated). When set, ALLOWED_ORIGINS is ignored.
# TRUSTED_ORIGINS=https://ddx.care

# HMAC secret for WebSocket authentication. When empty, tokens are not required (dev mode).
# WS_TOKEN_SECRET=

# Job TTL in milliseconds (default: 3600000 = 60 minutes)
# JOB_TTL_MS=3600000

# Log output format. Set to "json" for JSON-line output; omit for human-readable (default: human-readable)
# LOG_FORMAT=json

# Path to persistent audit log file (default: disabled / empty string)
# AUDIT_LOG_PATH=./logs/audit.log

# Max audit log file size in MB before rotation (default: 10)
# AUDIT_LOG_MAX_SIZE_MB=10

# Number of rotated audit log files to retain (default: 5)
# AUDIT_LOG_MAX_FILES=5

# Path to SQLite job database (default: jobs.sqlite)
# DB_PATH=jobs.sqlite

# Max concurrent specialist agents per round (default: 3)
# MAX_SPECIALIST_CONCURRENCY=3

# Base delay in ms between agent generation retries (default: 1000)
# AGENT_GENERATE_RETRY_BASE_DELAY=1000

# Diagnosis workflow timeout in ms (default: 900000 = 15 minutes)
# DIAGNOSIS_TIMEOUT_MS=900000

# Rate limiter max entries before evicting oldest (default: 10000)
# RATE_LIMIT_MAX_ENTRIES=10000

# Set to "production" to disable dev-mode warnings and HMR (default: development)
# NODE_ENV=production

# Caddy basic auth: bcrypt hash for the admin user (required when using Caddyfile)
# Generate with:  caddy hash-password --plaintext 'your-password'
# BASIC_AUTH_HASH=
