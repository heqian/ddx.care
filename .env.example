# Required: Google AI API key for Gemini models
GOOGLE_GENERATIVE_AI_API_KEY=

# Server port (default: 3000)
# PORT=3000

# Override specialist agent model (default: google/gemini-3.1-pro-preview)
# SPECIALIST_MODEL=google/gemini-3.1-pro-preview

# Override CMO orchestrator model (default: google/gemini-3.1-pro-preview)
# ORCHESTRATOR_MODEL=google/gemini-3.1-pro-preview

# Max consultation rounds per diagnosis (default: 3)
# MAX_DIAGNOSIS_ROUNDS=3

# Rate limit: max diagnosis requests per IP per window (default: 5)
# RATE_LIMIT_MAX_REQUESTS=5

# Rate limit: time window in ms (default: 3600000 = 1 hour)
# RATE_LIMIT_WINDOW_MS=3600000

# Max concurrent diagnostic workflows (default: 3)
# MAX_CONCURRENT_WORKFLOWS=3

# Set to "1" to use mock LLM responses (for testing)
# MOCK_LLM=1
