# Required: Together AI API key
TOGETHER_API_KEY=

# Server port (default: 3000)
# PORT=3000

# Override specialist agent model (default: togetherai/openai/gpt-oss-120b)
# SPECIALIST_MODEL=togetherai/openai/gpt-oss-120b

# Override CMO orchestrator model (default: togetherai/openai/gpt-oss-120b)
# ORCHESTRATOR_MODEL=togetherai/openai/gpt-oss-120b

# Max consultation rounds per diagnosis (default: 3)
# MAX_DIAGNOSIS_ROUNDS=3

# Rate limit: max diagnosis requests per IP per window (default: 5)
# RATE_LIMIT_MAX_REQUESTS=5

# Rate limit: time window in ms (default: 60000 = 1 minute)
# RATE_LIMIT_WINDOW_MS=60000

# Max concurrent diagnostic workflows (default: 3)
# MAX_CONCURRENT_WORKFLOWS=3

# Set to "1" to use mock LLM responses (for testing)
# MOCK_LLM=1
