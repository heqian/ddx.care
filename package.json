{
  "name": "ddx.care",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot index.ts",
    "build": "bun build ./index.html --outdir ./dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/api.test.ts tests/tools.test.ts tests/api-integration.test.ts tests/workflow.test.ts",
    "test:frontend": "bun test tests/frontend.test.tsx",
    "test:e2e": "bunx playwright test",
    "test:all": "bun run test && bun run test:frontend && bun run test:e2e",
    "test:integration": "RUN_INTEGRATION=1 bun test tests/api-integration.test.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "happy-dom": "^20.8.9",
    "mastra": "^1.5.0",
    "tailwindcss": "^4.2.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@mastra/core": "^1.24.1",
    "isomorphic-dompurify": "^3.8.0",
    "marked": "^17.0.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  }
}
